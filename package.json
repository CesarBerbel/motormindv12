    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "nodemailer": "^7.0.7",
    "tailwindcss": "^3.4.17",
    "@tailwindcss/forms": "^0.5.9",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5",
    "lucide-react": "^0.462.0",
    "class-variance-authority": "^0.7.1",
