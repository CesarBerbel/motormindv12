# ============================================================
# MOTORMIND — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no git
# ============================================================

# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=GERE_COM_openssl_rand_-base64_32

# Banco de Dados (PostgreSQL)
# Dev (Docker Compose): postgresql://motormind:motormind@localhost:5432/motormind
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# E-mail (para recuperação de senha)
# Para dev, use Ethereal: https://ethereal.email/
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="MotorMind <no-reply@example.com>"

# VPS Deploy (usado pelo CI/CD)
VPS_HOST=your-vps-ip-or-hostname
VPS_USER=deploy
VPS_SSH_PORT=22
VPS_APP_DIR=/opt/motormind

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000
